			local name = fullPath:match("([^\\/]+)%.json$");
			if name then
				local btn = Instance.new("TextButton", listScroll);
				btn.Size = UDim2.new(1, -6, 0, 30);
				btn.Position = UDim2.new(0, 3, 0, y);
