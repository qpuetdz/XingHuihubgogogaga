		else
			OfficialSky:Disable();
		end
		if cfg.WallbangDesyncEnabled then
			wallbangDesync:Start();
		else
			wallbangDesync:Stop();
		end
		if cfg.WallbangV2Enabled then
			wallbangV2:Start();
		else
			wallbangV2:Stop();
		end
