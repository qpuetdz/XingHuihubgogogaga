		SilentAim.MaxDistance = cfg.SilentAimMaxDistance or 300;
		MagicEnabled = cfg.MagicEnabled or false;
		if MagicEnabled then
			MagicSetupGunHook();
		end
		if cfg.MagicConfig then
			for k, v in pairs(cfg.MagicConfig) do
				MagicConfig[k] = v;
			end
		end
		SpeedEnabled = cfg.SpeedEnabled or false;
		InfiniteJumpEnabled = cfg.InfiniteJumpEnabled or false;
		SpeedMultiplier = cfg.SpeedMultiplier or 0.3;
		JumpMultiplier = cfg.JumpMultiplier or 2;
		GravitySetting = cfg.GravitySetting or 1;
		OfficialSky.Enabled = cfg.OfficialSkyEnabled or false;
