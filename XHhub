local function getClosestEnemy()
	local myChar = LocalPlayer.Character;
	if not myChar then
		return nil;
	end
	local myRoot = myChar:FindFirstChild("HumanoidRootPart");
	if not myRoot then
		return nil;
	end
	local myPos = myRoot.Position;
	local best, bestDist = nil, math.huge;
	for _, plr in ipairs(Players:GetPlayers()) do
		if (plr == LocalPlayer) then
			continue;
		end
		if SilentAim.TeamCheck then
			if (LocalPlayer.Team and (plr.Team == LocalPlayer.Team)) then
				continue;
			end
			local team1 = LocalPlayer:GetAttribute("TeamID");
			local team2 = plr:GetAttribute("TeamID");
			if (team1 and team2 and (team1 == team2)) then
				continue;
			end
		end
		local char = plr.Character;
		if not char then
			continue;
		end
		local part = char:FindFirstChild(SilentAim.AimPart);
		local hum = char:FindFirstChildWhichIsA("Humanoid");
		if not (part and hum and (hum.Health > 0)) then
			continue;
		end
		local dist = (part.Position - myPos).Magnitude;
		if (SilentAim.LimitRange and (dist > SilentAim.MaxDistance)) then
			continue;
		end
		if (dist < bestDist) then
			bestDist = dist;
			best = part;
		end
	end
	return best;
end
